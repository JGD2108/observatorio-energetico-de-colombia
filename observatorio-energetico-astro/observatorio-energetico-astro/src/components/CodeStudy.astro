---
import { Code } from 'astro:components';
const {
  index,
  titleEs,
  titleEn,
  source,
  code,
  lang = 'python',
  whatEs,
  whatEn,
  stepsEs = [],
  stepsEn = [],
  whyEs,
  whyEn,
  defenseEs,
  defenseEn,
  caveatEs,
  caveatEn
} = Astro.props;
---
<article class="code-study reveal">
  <header class="code-study__header">
    <span class="code-study__index">{index}</span>
    <div>
      <p class="code-study__source">{source}</p>
      <h3><span class="lang-es">{titleEs}</span><span class="lang-en">{titleEn}</span></h3>
    </div>
  </header>
  <div class="code-study__body">
    <div class="code-panel">
      <div class="code-panel__bar">
        <span>{lang}</span>
        <button class="copy-code" type="button" data-copy-target={`code-${index}`}>
          <span class="lang-es">Copiar</span><span class="lang-en">Copy</span>
        </button>
      </div>
      <div class="code-panel__content" id={`code-${index}`} data-raw-code={code}>
        <Code code={code} lang={lang} theme="github-dark" wrap={false} />
      </div>
    </div>
    <div class="code-explainer">
      <section>
        <span class="explainer-label"><span class="lang-es">Qué hace</span><span class="lang-en">What it does</span></span>
        <p><span class="lang-es">{whatEs}</span><span class="lang-en">{whatEn}</span></p>
      </section>
      <ol class="step-list lang-es">
        {stepsEs.map((step) => <li>{step}</li>)}
      </ol>
      <ol class="step-list lang-en">
        {stepsEn.map((step) => <li>{step}</li>)}
      </ol>
      <section class="decision-box decision-box--why">
        <span class="explainer-label"><span class="lang-es">Por qué se decidió así</span><span class="lang-en">Why this decision</span></span>
        <p><span class="lang-es">{whyEs}</span><span class="lang-en">{whyEn}</span></p>
      </section>
      <section class="decision-box decision-box--defense">
        <span class="explainer-label"><span class="lang-es">Cómo defenderlo</span><span class="lang-en">How to defend it</span></span>
        <p><span class="lang-es">{defenseEs}</span><span class="lang-en">{defenseEn}</span></p>
      </section>
      {(caveatEs || caveatEn) && <section class="decision-box decision-box--caveat">
        <span class="explainer-label"><span class="lang-es">Límite actual</span><span class="lang-en">Current limitation</span></span>
        <p><span class="lang-es">{caveatEs}</span><span class="lang-en">{caveatEn}</span></p>
      </section>}
    </div>
  </div>
</article>
