---
const { titleEs, titleEn, captionEs, captionEn, diagram, id = 'diagram' } = Astro.props;
---
<figure class="mermaid-card reveal" id={id}>
  <figcaption>
    <div>
      <span class="eyebrow"><span class="lang-es">Diagrama vivo</span><span class="lang-en">Live diagram</span></span>
      <h3><span class="lang-es">{titleEs}</span><span class="lang-en">{titleEn}</span></h3>
      <p><span class="lang-es">{captionEs}</span><span class="lang-en">{captionEn}</span></p>
    </div>
    <div class="diagram-actions">
      <button type="button" class="diagram-zoom" data-diagram-target={id} aria-expanded="false"><span aria-hidden="true">⤢</span> <span class="lang-es">Ampliar</span><span class="lang-en">Expand</span></button>
    </div>
  </figcaption>
  <div class="mermaid-stage">
    <pre class="mermaid">{diagram}</pre>
  </div>
</figure>
